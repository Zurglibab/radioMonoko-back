# Example environment variables for radioMonoko-back
# Copy to `.env` and fill values; do NOT commit real secrets

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=your_db
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional if your Redis requires a password
REDIS_PASSWORD=

# JWT
JWT_SECRET=replace_this_with_a_strong_random_secret
JWT_EXPIRES_IN=8h

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# SMTP (for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=ton.compte@gmail.com
SMTP_PASS=APP_PASSWORD_GENERATED_BY_GOOGLE
SMTP_FROM="Ton Nom <ton.compte@gmail.com>"

# External API (example)
RADIOFRANCE_ENDPOINT=
RADIOFRANCE_TOKEN=

# CORS
# Set to '*' to allow all origins (dev only). In production, set to your front-end origin.
CORS_ORIGIN=http://localhost:3000

# Scheduler / env
NODE_ENV=development
BRANDS_REFRESH_INTERVAL_HOURS=
BRANDS_REFRESH_CRON=0 0,12 * * *
BRANDS_REFRESH_TZ=Europe/Paris

